# RSA public key from BetterAuth JWKS endpoint.
# To extract: curl -s http://localhost:3000/api/auth/jwks | node infra/scripts/extract-jwks-pem.js
# Paste the full PEM block (including -----BEGIN/END----- lines) below.
BETTER_AUTH_RSA_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
MIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEA...
-----END PUBLIC KEY-----"
