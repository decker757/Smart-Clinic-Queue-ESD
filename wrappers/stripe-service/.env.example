# Stripe API key (test mode or live mode)
STRIPE_API_KEY=sk_test_your_stripe_api_key
STRIPE_WEBHOOK_SIGNING_SECRET=whsec_your_signing_secret

# Frontend redirect URLs after payment
FRONTEND_BASE_URL=http://localhost:5173
STRIPE_SUCCESS_URL=http://localhost:5173/success
STRIPE_CANCEL_URL=http://localhost:5173/cancel

# Internal service URLs
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/
AUTH_SERVICE_URL=http://auth-service:3000

# Consultation fee (smallest currency unit, e.g. cents)
CONSULTATION_FEE_CENTS=5000
CURRENCY=sgd
