FROM node:22-alpine

WORKDIR /app

# Install dependencies as a separate layer so they're cached
# Source code is mounted as a volume at runtime (hot reload)
COPY frontend/vue-app/package*.json ./
RUN npm ci

# --host exposes the dev server to all interfaces so Docker port mapping works
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
