# API base URL — no trailing slash
# Local:      leave empty (Vite proxies /api/* or hit services directly)
# Production: https://<api-gateway-id>.execute-api.<region>.amazonaws.com
VITE_API_BASE_URL=

# WebSocket base URL (ALB or CloudFront)
VITE_WS_BASE_URL=

# Auth mode: "betterauth" (local dev) or "cognito" (production)
VITE_AUTH_MODE=betterauth

# Cognito (required when VITE_AUTH_MODE=cognito)
VITE_COGNITO_CLIENT_ID=
VITE_COGNITO_ENDPOINT=https://cognito-idp.<region>.amazonaws.com/
