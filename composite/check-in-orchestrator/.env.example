SERVICE_NAME=check-in-orchestrator
SERVICE_VERSION=1.0.0
ENVIRONMENT=development
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=INFO

APPOINTMENT_SERVICE_URL=http://appointment-service:8000
